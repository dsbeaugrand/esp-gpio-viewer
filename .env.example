# esp-gpio-viewer example firmware — WiFi credentials (2.4 GHz, STA mode only).
# Copy this file to `.env` and fill in your real values. `.env` is gitignored.
#
# These are baked into the example firmware at COMPILE TIME via env!("WIFI_SSID") /
# env!("WIFI_PASSWORD"), so a build/flash reads them from the environment.
#
# ESPFLASH_PORT pins which connected board gets flashed. Verified on this machine:
#   /dev/cu.usbserial-0001  -> classic ESP32 (rev v3.1)   <-- default here
#   /dev/cu.wchusbserial210 -> ESP32-S3 (rev v0.2)
WIFI_SSID=your-ssid
WIFI_PASSWORD=your-password
ESPFLASH_PORT=/dev/cu.usbserial-0001
